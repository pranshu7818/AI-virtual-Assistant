{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm start"
  },
  "services": {
    "backend": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm install"
      },
      "deploy": {
        "startCommand": "npm start",
        "healthcheckPath": "/",
        "healthcheckTimeout": 300
      },
      "source": {
        "rootDirectory": "Backend"
      }
    },
    "frontend": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm run build"
      },
      "deploy": {
        "startCommand": "npm run preview",
        "healthcheckPath": "/",
        "healthcheckTimeout": 300
      },
      "source": {
        "rootDirectory": "Frontend"
      }
    }
  }
}